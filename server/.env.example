# Database
DATABASE_URL=postgres://tc:tc@db:5432/threatcaddy

# Server
PORT=3001
FILE_STORAGE_PATH=/data/files

# CORS — comma-separated origins (default: * allows all)
ALLOWED_ORIGINS=https://your-app.example.com

# JWT Ed25519 keys (required)
# Generate with:
#   openssl genpkey -algorithm Ed25519 -out private.pem
#   openssl pkey -in private.pem -pubout -out public.pem
# Then set as single-line values (replace newlines with \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Trust proxy headers (X-Forwarded-For) for rate limiting
# Set to 1 only when running behind a reverse proxy (nginx, Cloudflare, etc.)
TRUST_PROXY=0

# LLM API keys (optional — enable AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
